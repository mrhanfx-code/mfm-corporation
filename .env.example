# ─────────────────────────────────────────────
# MFM Corp Dashboard — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# NextAuth secret — generate with: node -e "require('crypto').randomBytes(32).toString('base64')"
AUTH_SECRET=your-random-base64-secret-here

# Admin password hash — base64 encoded to avoid dotenv $ expansion
# Generate with:
#   node -e "const b=require('bcryptjs');const h=b.hashSync('yourpassword',10);console.log(Buffer.from(h).toString('base64'))"
# Default login: username=admin, password=admin123 (CHANGE THIS in production)
ADMIN_PASSWORD_HASH_B64=your-base64-bcrypt-hash-here

# Cloudflare Workers backend URL (no trailing slash)
WORKERS_API_URL=https://mfm-corporation-telegram-bot.mrhan-fx.workers.dev

# Cloudflare Workers API secret — ROTATE the old F@rihan123 secret immediately
# Generate new: node -e "require('crypto').randomBytes(32).toString('hex')"
WORKERS_API_SECRET=your-new-workers-secret-here
