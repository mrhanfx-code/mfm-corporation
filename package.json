{
  "name": "mfm-corporation",
  "version": "1.0.0",
  "type": "module",
  "description": "MFM Corporation - CEO Remy Command Center with 19 specialized teams",
  "main": "index.html",
  "scripts": {
    "build": "echo 'Build completed - Static files ready for deployment'",
    "dev": "echo 'Development mode - Open index.html in browser'",
    "deploy": "echo 'Deploy to GitHub Pages via GitHub Actions'",
    "deploy:cloudflare": "wrangler pages deploy",
    "dev:cloudflare": "wrangler pages dev",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "echo 'Linting would run here'",
    "serve": "python -m http.server 8000",
    "monitor": "node scripts/synthetic-monitoring.js"
  },
  "keywords": [
    "corporate",
    "automation",
    "ai",
    "teams",
    "management",
    "ceo",
    "chat",
    "real-time"
  ],
  "author": "CEO Remy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrhanfx-code/mfm-corporation.git"
  },
  "homepage": "https://mrhanfx-code.github.io/mfm-corporation",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@sentry/node": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "miniflare": "^4.20260526.0",
    "playwright": "^1.48.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
